# Nature's Way Soil b-roll social video Cloud Run Job
# Copy these into Cloud Run Job environment variables or Secret Manager mappings.

USE_SECRET_MANAGER=true
GOOGLE_CLOUD_PROJECT=natureswaysoil-video
GCLOUD_PROJECT=natureswaysoil-video
GCP_PROJECT=natureswaysoil-video

VIDEO_STYLE=broll_ken_burns
VIDEO_PROVIDER=did
GCS_PUBLIC_BUCKET=natureswaysoil-social-videos
VIDEO_PUBLIC_BUCKET=natureswaysoil-social-videos
VIDEO_PUBLIC_URL_BASE=https://storage.googleapis.com/natureswaysoil-social-videos

ENABLE_PLATFORMS=youtube,instagram,facebook
YT_PRIVACY_STATUS=public
DRY_RUN_LOG_ONLY=false
SEED_PRODUCT_LIMIT=5
VARIATIONS_PER_PRODUCT=5
ROTATION_STATE_FILE=data/rotation-state.json
ROTATION_STATE_PERSIST_TO_GCS=true
ROTATION_STATE_GCS_OBJECT=state/rotation-state.json

# Optional platforms
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
FACEBOOK_GROUPS_ACCESS_TOKEN=
