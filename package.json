{
  "name": "social-video-automation",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Nature's Way Soil scheduled product video generation and social posting automation.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:cloudrun": "NODE_OPTIONS=--max-old-space-size=2048 VIDEO_STYLE=broll_ken_burns node dist/post-scheduled.js",
    "post:scheduled": "NODE_OPTIONS=--max-old-space-size=2048 VIDEO_STYLE=broll_ken_burns ts-node --transpile-only scripts/post-scheduled.ts",
    "post:manual-video": "NODE_OPTIONS=--max-old-space-size=2048 ts-node --transpile-only scripts/post-manual-video.ts",
    "test:dry": "NODE_OPTIONS=--max-old-space-size=2048 DRY_RUN_LOG_ONLY=true VIDEO_STYLE=broll_ken_burns ts-node --transpile-only scripts/post-scheduled.ts",
    "test:creative": "VIDEO_PROVIDER=did ts-node --transpile-only scripts/test-creative-video.ts",
    "validate": "ts-node --transpile-only scripts/validate-config.ts",
    "validate:dry": "DRY_RUN_LOG_ONLY=true ts-node --transpile-only scripts/validate-config.ts",
    "health": "ts-node --transpile-only scripts/server.ts",
    "analyze-groups": "ts-node --transpile-only scripts/analyze-facebook-engagement.ts",
    "fetch:analytics": "ts-node --transpile-only scripts/fetch-analytics.ts",
    "images:download": "ts-node --transpile-only scripts/download-product-images.ts"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.16.0",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "openai": "^4.67.3"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
